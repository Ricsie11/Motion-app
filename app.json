{
  "expo": {
    "name": "DailyTask",
    "slug": "DailyTask",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "motionapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.jpg"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1209",
        "foregroundImage": "./assets/images/icon.jpg"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ricsie.DailyTask"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A1209",
          "android": {
            "image": "./assets/images/icon.jpg",
            "imageWidth": 76
          }
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1dab7a47-a9fd-41d3-bec1-b586f05dc5d0"
      }
    },
    "owner": "ricsie"
  }
}
